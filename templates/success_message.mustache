{{!
    @template block_dixeo_designer/success_message

    Displays a success message after course creation

    Context variables required for this template:
    * coursename
    * courseid

    Example context (json):
    {
        "coursename": "Generated Course Name",
        "courseid": 42
    }
}}
<div id="success_message_container" class="justify-content-center align-items-center mt-3">
    <div class="alert alert_course_generated text-center" role="alert">
        {{#str}} course_generated, block_dixeo_designer, {{coursename}} {{/str}}
        <div class="side-by-side">
            <a href="{{wwwroot}}/course/view.php?id={{courseid}}" target="_blank" class="btn button_view_course text-white d-flex align-items-center" title="{{#str}} view_course, block_dixeo_designer {{/str}}">
                <img src="{{wwwroot}}/blocks/dixeo_designer/pix/dixeo-white.svg" alt="Dixeo" width="25" height="25">
                <span> {{#str}} view_course, block_dixeo_designer {{/str}} </span>
            </a>
            <a href="{{generate_another_url}}" class="btn button_generate_another d-flex align-items-center" title="{{#str}} generate_another, block_dixeo_designer {{/str}}">
                <span> {{#str}} generate_another, block_dixeo_designer {{/str}} </span>
            </a>
        </div>
    </div>
</div>
