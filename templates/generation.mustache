{{!
    @template block_dixeo_designer/generation

    Generation animation

    Context variables required for this template:
    * None

    Example context (json):
    {
        "job_id": 12345
    }
}}
<div class="generation-container text-center d-none" data-job_id="{{job_id}}" data-status="0">
    <h2 class="mb-4">{{#str}} heading2, block_dixeo_designer {{/str}}</h2>
    <div id="loader" class="justify-content-center align-items-center">
        <p>{{#str}} generating_course, block_dixeo_designer {{/str}}</p>
        <object type="image/svg+xml" data="{{config.wwwroot}}/blocks/dixeo_designer/pix/dixeo-animated.svg" width="80" height="80"></object>
        <div class="s-progress s-progress__segmented">
            <div class="s-progress--bar" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" style="width: 0%;"></div>
            <ol class="s-progress--segments" data-steps="4">
                <li class="s-progress--segment-20">
                    <span class="generation-step" data-step="1">{{#str}} step_uploading_files, block_dixeo_designer {{/str}}</span>
                </li>
                <li class="s-progress--segment-20">
                    <span class="generation-step" data-step="2">{{#str}} step_generating_structure, block_dixeo_designer {{/str}}</span>
                </li>
                <li class="s-progress--segment-40">
                    <span class="generation-step" data-step="3">{{#str}} step_generating_content, block_dixeo_designer {{/str}}</span>
                </li>
                <li class="s-progress--segment-20">
                    <span class="generation-step" data-step="4">{{#str}} step_finalizing_details, block_dixeo_designer {{/str}}</span>
                </li>
                <li></li>
            </ol>
        </div>
        <div class="cancel-btn">
            <button type="button" class="btn btn-secondary btn-cancel-draft" data-action="cancel-draft">
                <span class="btn-cancel-draft-idle">{{#str}} designer_cancel, block_dixeo_designer {{/str}}</span>
                <span class="btn-cancel-draft-loading d-none">
                    <i class="icon fa fa-spinner fa-spin fa-fw" role="presentation" aria-hidden="true"></i>
                    <span class="btn-cancel-draft-loading-text">{{#str}} designer_cancelling, block_dixeo_designer {{/str}}</span>
                </span>
            </button>
        </div>
    </div>
</div>
