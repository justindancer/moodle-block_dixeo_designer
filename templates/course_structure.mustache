{{!
    @template block_dixeo_designer/course_structure

    Course structure template for the JSON designer.

    Context variables required for this template:
    * title - Course title
    * summary - Course summary (optional)
    * image - Course image (optional)
    * jobid - Job ID
    * sections - Array of sections
    * strings - From AMD (expand_all, module_summary_label, placeholders for empty editables, etc.)
    * designer_image_show_loading - When true, show generating spinner (course image policy + no image yet)
    * designer_image_allow_edit - When true, show regenerate control (course image edit policy + has image)
    * designer_show_course_image_area - When false, hide the course image frame (no image and generation disabled)
}}
<div class="course-overview">
    {{#designer_show_course_image_area}}
    <div class="course-image {{#designer_image_show_loading}}is-loading{{/designer_image_show_loading}}" data-designer-course-image-root>
        {{#image}}
        <img src="{{image}}" alt="{{#title}}{{title}}{{/title}}{{^title}}{{#str}} designer_placeholder_course_title, block_dixeo_designer {{/str}}{{/title}}" loading="lazy" width="280" height="157" decoding="async" data-designer-course-image>
        {{/image}}
        <div class="course-image-placeholder {{#image}}d-none{{/image}}" data-designer-course-image-placeholder>
            {{#designer_image_show_loading}}
            <span class="fa fa-spinner fa-spin" aria-hidden="true"></span>
            <span class="course-image-placeholder-label">{{#str}} designer_image_generating_status, block_dixeo_designer {{/str}}</span>
            {{/designer_image_show_loading}}
        </div>
        {{#designer_image_allow_edit}}
        <button type="button"
                class="course-image-regenerate-btn"
                data-designer-image-regenerate-open
                aria-label="{{#str}} designer_image_regenerate, block_dixeo_designer {{/str}}"
                title="{{#str}} designer_image_regenerate, block_dixeo_designer {{/str}}">
            <i class="fa fa-pen" aria-hidden="true"></i>
        </button>
        {{/designer_image_allow_edit}}
    </div>
    {{/designer_show_course_image_area}}
    <h2 class="course-title editable" data-path="title" data-placeholder="{{strings.placeholder_course_title}}">{{title}}</h2>
    <div class="edit-controls"></div>
    <p class="course-summary editable text-muted" data-path="summary" data-placeholder="{{strings.placeholder_course_summary}}">{{summary}}</p>
    <div class="edit-controls"></div>
</div>

<div class="designer-image-preview-modal d-none" data-designer-image-preview-modal aria-hidden="true">
    <div class="designer-image-preview-backdrop" data-designer-image-preview-close></div>
    <div class="designer-image-preview-dialog" role="dialog" aria-modal="true" aria-label="{{title}}">
        <button type="button"
                class="designer-image-preview-close"
                data-designer-image-preview-close
                aria-label="{{#str}} designer_image_close_dialog, block_dixeo_designer {{/str}}">
            <span aria-hidden="true">&times;</span>
        </button>
        <img src="{{image}}" alt="{{#title}}{{title}}{{/title}}{{^title}}{{#str}} designer_placeholder_course_title, block_dixeo_designer {{/str}}{{/title}}" loading="lazy" decoding="async" data-designer-image-preview-img>
    </div>
</div>

<div class="designer-image-regenerate-modal d-none" data-designer-image-regenerate-modal aria-hidden="true">
    <div class="designer-image-regenerate-backdrop" data-designer-image-regenerate-close></div>
    <div class="designer-image-regenerate-dialog"
         role="dialog"
         aria-modal="true"
         aria-label="{{#str}} designer_image_regenerate_dialog_title, block_dixeo_designer {{/str}}">
        <div class="designer-image-regenerate-header">
            <h3>{{#str}} designer_image_regenerate_dialog_title, block_dixeo_designer {{/str}}</h3>
            <button type="button"
                    class="designer-image-regenerate-close"
                    data-designer-image-regenerate-close
                    aria-label="{{#str}} designer_image_close_dialog, block_dixeo_designer {{/str}}">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
        <div class="designer-image-regenerate-body">
            <p class="designer-image-regenerate-label">{{#str}} designer_image_regenerate_dialog_label, block_dixeo_designer {{/str}}</p>
            <textarea rows="4"
                      class="designer-image-regenerate-prompt"
                      data-designer-image-regenerate-prompt
                      placeholder="{{#str}} designer_image_regenerate_dialog_placeholder, block_dixeo_designer {{/str}}"></textarea>
            <p class="designer-image-regenerate-message d-none" data-designer-image-regenerate-message></p>
            <div class="designer-image-regenerate-loading d-none" data-designer-image-regenerate-loading>
                <span class="fa fa-spinner fa-spin" aria-hidden="true"></span>
                <span>{{#str}} designer_image_generating_status, block_dixeo_designer {{/str}}</span>
            </div>
        </div>
        <div class="designer-image-regenerate-actions">
            <button type="button"
                    class="btn btn-secondary"
                    data-designer-image-regenerate-close>{{#str}} designer_cancel, block_dixeo_designer {{/str}}</button>
            <button type="button"
                    class="btn btn-primary"
                    data-designer-image-regenerate-submit>{{#str}} designer_image_generate, block_dixeo_designer {{/str}}</button>
        </div>
    </div>
</div>

{{#hasSections}}
<div class="course-sections">
    <div class="collapse-expand-row d-flex justify-content-end align-items-center">
        <span class="collapse-expand-links">
            <a href="#" id="link-expand-all" class="link-expand">{{strings.expand_all}}</a>
            <a href="#" id="link-collapse-all" class="d-none">{{strings.collapse_all}}</a>
        </span>
    </div>
    {{#sections}}
    <div class="add-section-container position-relative">
        <button class="btn-add-section btn btn-sm btn-outline-primary" title="{{strings.add_section}}" data-section-index="{{index}}">
            <i class="fa fa-plus"></i>
        </button>
    </div>
    <div class="section-item border rounded" data-section-idx="{{index}}">
        <div class="item-actions">
            <button class="btn-copy-item" title="{{strings.duplicate}}" data-action="copy"><i class="fa fa-copy"></i></button>
            <button class="btn-delete-item btn-danger" title="{{strings.delete}}" data-action="delete"><i class="fa fa-trash"></i></button>
        </div>

        <div class="section-header d-flex align-items-start">
            <button class="btn btn-link p-0 section-toggle text-decoration-none collapsed" type="button"
                    data-toggle="collapse" data-target="#section-{{jobid}}-{{index}}" aria-expanded="false">
                <i class="fa fa-chevron-right"></i>
            </button>

            <div class="section-content flex-grow-1">
                <h4 class="section-title editable" data-path="sections[{{index}}].title" data-placeholder="{{strings.placeholder_section_title}}">{{title}}</h4>
                <div class="edit-controls"></div>
                <p class="section-summary editable text-muted" data-path="sections[{{index}}].summary" data-placeholder="{{strings.placeholder_section_summary}}">{{summary}}</p>
                <div class="edit-controls"></div>
            </div>
        </div>

        {{#hasModules}}
        <div class="collapse section-collapse" id="section-{{jobid}}-{{index}}">
            <div class="modules-list">
                {{#modules}}
                <div class="add-module-container position-relative">
                    <button class="btn-add-module btn btn-sm btn-outline-secondary" title="{{strings.add_activity}}" data-section-index="{{sectionIndex}}" data-module-index="{{index}}">
                        <i class="fa fa-plus"></i>
                    </button>
                </div>
                <div class="module-item d-flex bg-light rounded" data-module-idx="{{index}}">
                    <div class="item-actions">
                        <button class="btn-copy-item" title="{{strings.duplicate}}" data-action="copy"><i class="fa fa-copy"></i></button>
                        <button class="btn-delete-item btn-danger" title="{{strings.delete}}" data-action="delete"><i class="fa fa-trash"></i></button>
                    </div>

                    <div class="module-type-select-wrapper text-primary"
                         data-section-index="{{sectionIndex}}"
                         data-module-index="{{index}}"
                         data-path="sections[{{sectionIndex}}].modules[{{index}}].type">
                        <button type="button" class="module-type-select-toggle" aria-haspopup="listbox" aria-expanded="false" aria-label="{{strings.change_activity_type}}">
                            <span class="module-type-select-toggle-main">
                                <span class="dixeo-designer-module-type-icon dixeo-designer-module-type-icon--toggle"
                                      style="--dixeo-activity-icon: url('{{iconurl}}');"
                                      role="presentation" aria-hidden="true"></span>
                            </span>
                            <i class="fa fa-chevron-down module-type-select-chevron" aria-hidden="true"></i>
                        </button>
                        <div class="module-type-select-dropdown d-none" role="listbox" aria-hidden="true">
                            {{#moduleTypeOptions}}
                            <div class="module-type-option" data-value="{{value}}" role="option">
                                <span class="dixeo-designer-module-type-icon dixeo-designer-module-type-icon--option"
                                      style="--dixeo-activity-icon: url('{{iconurl}}');"
                                      role="presentation" aria-hidden="true"></span>
                                <span>{{label}}</span>
                            </div>
                            {{/moduleTypeOptions}}
                        </div>
                    </div>

                    <div class="module-details flex-grow-1">
                        <div class="module-type text-muted small">{{typeLabel}}</div>
                        <h5 class="module-title editable" data-path="sections[{{sectionIndex}}].modules[{{index}}].title" data-placeholder="{{strings.placeholder_module_title}}">{{title}}</h5>
                        <div class="edit-controls"></div>
                        <div class="module-summary-label text-muted small">{{strings.module_summary_label}}</div>
                        <p class="module-summary editable text-muted small" data-path="sections[{{sectionIndex}}].modules[{{index}}].summary" data-placeholder="{{strings.placeholder_module_summary}}">{{summary}}</p>
                        <div class="edit-controls"></div>
                        <div class="module-instructions-label text-muted small">{{strings.module_instructions_label}}</div>
                        <p class="module-instructions editable text-muted small" data-path="sections[{{sectionIndex}}].modules[{{index}}].instructions" data-placeholder="{{strings.placeholder_module_instructions}}">{{instructions}}</p>
                        <div class="edit-controls"></div>
                    </div>
                </div>
                {{/modules}}
                <div class="add-module-container position-relative">
                    <button class="btn-add-module btn btn-sm btn-outline-secondary" title="{{strings.add_activity}}" data-section-index="{{index}}" data-module-index="{{modules.length}}">
                        <i class="fa fa-plus"></i>
                    </button>
                </div>
            </div>
        </div>
        {{/hasModules}}
        {{^hasModules}}
        <div class="add-module-container-empty">
            <button class="btn-add-module btn btn-sm btn-outline-secondary" title="{{strings.add_activity}}" data-section-index="{{index}}" data-module-index="0">
                <i class="fa fa-plus"></i>
            </button>
        </div>
        {{/hasModules}}
    </div>
    {{/sections}}
    <div class="add-section-container position-relative">
        <button class="btn-add-section btn btn-sm btn-outline-primary" title="{{strings.add_section}}" data-section-index="{{sections.length}}">
            <i class="fa fa-plus"></i>
        </button>
    </div>
</div>
{{/hasSections}}
{{^hasSections}}
<div class="add-section-container-empty">
    <button class="btn-add-section btn btn-sm btn-outline-primary" title="{{strings.add_section}}" data-section-index="0">
        <i class="fa fa-plus"></i>
    </button>
</div>
{{/hasSections}}
